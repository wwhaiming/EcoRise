# ──────────────────────────────────────────────
# EcoRise — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────────

# Anthropic Claude API (for AI image analysis, quest generation)
ANTHROPIC_API_KEY=

# Database (SQLite path, defaults to ./ecorise.db)
DATABASE_URL=./ecorise.db

# JWT secret for session tokens
JWT_SECRET=change-me-to-a-random-string

# Cloudinary (optional — for image uploads)
CLOUDINARY_URL=

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server port
PORT=3001
